        inst:spec_LIR2450_Self-Discharge_Rate,
        inst:spec_LIR2450_Standard_Charge_Current,
        inst:spec_LIR2450_Standard_Discharge_Current,
        inst:spec_LIR2450_Weight ;
    rdfs:comment "Source: lir2450_EEMB.pdf" .

inst:battery_PL-9059156 a batt:Battery ;
    rdfs:label "Battery: PL-9059156" ;
    batt:batteryModel "PL-9059156" ;
    batt:hasChemistry inst:Li-Polymer ;

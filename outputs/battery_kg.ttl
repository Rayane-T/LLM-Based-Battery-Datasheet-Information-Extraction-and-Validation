@prefix batt: <http://battery-ontology.org/schema#> .
@prefix inst: <http://battery-ontology.org/instance#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix unit: <http://battery-ontology.org/unit#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

inst:LTO a batt:Chemistry ;
    batt:chemistryType "LTO" .

inst:LiCoO2 a batt:Chemistry ;
    batt:chemistryType "LiCoO2" .

inst:LiFePO4 a batt:Chemistry ;
    batt:chemistryType "LiFePO4" .

inst:Li_Polymer a batt:Chemistry ;
    batt:chemistryType "Li-Polymer" .

inst:Li_ion a batt:Chemistry ;
    batt:chemistryType "Li-ion" .

inst:NMC a batt:Chemistry ;
    batt:chemistryType "NMC" .

inst:battery_16340 a batt:Battery ;
    rdfs:label "Battery: 16340" ;
    batt:batteryModel "16340" ;
    batt:hasChemistry inst:Li-ion ;
    batt:hasManufacturer inst:manufacturer_DNK_Power_o_Ltd ;
    batt:hasSpecification inst:spec_16340_Charge_Voltage,
        inst:spec_16340_Discharge_Cutoff_Voltage,
        inst:spec_16340_Energy,
        inst:spec_16340_Internal_Resistance,
        inst:spec_16340_Maximum_Charge_Current,
        inst:spec_16340_Maximum_Discharge_Current,
        inst:spec_16340_Minimum_Capacity,
        inst:spec_16340_Nominal_Capacity,
        inst:spec_16340_Nominal_Voltage,
        inst:spec_16340_Standard_Charge_Current,
        inst:spec_16340_Weight ;
    rdfs:comment "Source: 16340-battery-datasheet.pdf" .

inst:battery_FFH3DS a batt:Battery ;
    rdfs:label "Battery: FFH3DS" ;
    batt:batteryModel "FFH3DS" ;
    batt:hasChemistry inst:Li-ion ;
    batt:hasManufacturer inst:manufacturer_CATL ;
    batt:hasSpecification inst:spec_FFH3DS_Charge_Voltage,
        inst:spec_FFH3DS_Cycle_Life,
        inst:spec_FFH3DS_Discharge_Cutoff_Voltage,
        inst:spec_FFH3DS_Energy,
        inst:spec_FFH3DS_Internal_Resistance,
        inst:spec_FFH3DS_Maximum_Charge_Current,
        inst:spec_FFH3DS_Maximum_Discharge_Current,
        inst:spec_FFH3DS_Maximum_Operating_Temperature,
        inst:spec_FFH3DS_Maximum_Storage_Temperature,
        inst:spec_FFH3DS_Minimum_Operating_Temperature,
        inst:spec_FFH3DS_Minimum_Storage_Temperature,
        inst:spec_FFH3DS_Nominal_Capacity,
        inst:spec_FFH3DS_Nominal_Voltage,
        inst:spec_FFH3DS_Self-Discharge_Rate,
        inst:spec_FFH3DS_Standard_Charge_Current,
        inst:spec_FFH3DS_Standard_Discharge_Current,
        inst:spec_FFH3DS_Weight ;
    rdfs:comment "Source: CATL-86Ah-3.2V-LiFePO4-Prismatic-Battery-Cell-SpecificationDatasheet.pdf" .

inst:battery_LIR2450 a batt:Battery ;
    rdfs:label "Battery: LIR2450" ;
    batt:batteryModel "LIR2450" ;
    batt:hasChemistry inst:Li-ion ;

@prefix batt: <http://battery-ontology.org/schema#> .
@prefix inst: <http://battery-ontology.org/instance#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix unit: <http://battery-ontology.org/unit#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

inst:LTO a batt:Chemistry ;
    batt:chemistryType "LTO" .

inst:LiCoO2 a batt:Chemistry ;
    batt:chemistryType "LiCoO2" .

inst:LiFePO4 a batt:Chemistry ;
    batt:chemistryType "LiFePO4" .

inst:Li_Polymer a batt:Chemistry ;
    batt:chemistryType "Li-Polymer" .

inst:Li_ion a batt:Chemistry ;
    batt:chemistryType "Li-ion" .

inst:NMC a batt:Chemistry ;
    batt:chemistryType "NMC" .

<http://battery-ontology.org/schema> a owl:Ontology ;
    rdfs:label "Battery Specification Ontology" ;
    rdfs:comment "An ontology for representing battery datasheet specifications, including electrical, physical, and thermal properties." .

batt:ElectricalSpecification a owl:Class ;
    rdfs:label "Electrical Specification" ;
    rdfs:subClassOf batt:Specification .

batt:LifecycleSpecification a owl:Class ;
    rdfs:label "Lifecycle Specification" ;
    rdfs:subClassOf batt:Specification .

batt:PhysicalSpecification a owl:Class ;
    rdfs:label "Physical Specification" ;
    rdfs:subClassOf batt:Specification .

batt:ThermalSpecification a owl:Class ;
    rdfs:label "Thermal Specification" ;
    rdfs:subClassOf batt:Specification .

batt:batteryModel a owl:DatatypeProperty ;
    rdfs:label "Battery Model" ;
    rdfs:comment "Model name/number of the battery" ;
    rdfs:domain batt:Battery ;
    rdfs:range xsd:string .

batt:chemistryType a owl:DatatypeProperty ;
    rdfs:label "Chemistry Type" ;
    rdfs:comment "Battery chemistry type identifier" ;
    rdfs:domain batt:Chemistry ;
    rdfs:range xsd:string .

batt:hasChemistry a owl:ObjectProperty ;
    rdfs:domain batt:Battery ;
    rdfs:range batt:Chemistry .

batt:hasManufacturer a owl:ObjectProperty ;
    rdfs:domain batt:Battery ;
    rdfs:range batt:Manufacturer .

batt:hasSpecification a owl:ObjectProperty ;
    rdfs:domain batt:Battery ;
    rdfs:range batt:Specification .

batt:hasUnit a owl:ObjectProperty ;
    rdfs:domain batt:Specification ;
    rdfs:range batt:Unit .

batt:hasValue a owl:DatatypeProperty ;
    rdfs:label "Value" ;
    rdfs:comment "Numeric value of a specification" ;
    rdfs:domain batt:Specification ;
    rdfs:range xsd:float .

batt:manufacturerName a owl:DatatypeProperty ;
    rdfs:label "Manufacturer Name" ;
    rdfs:comment "Name of the manufacturer company" ;
    rdfs:domain batt:Manufacturer ;
    rdfs:range xsd:string .

batt:specName a owl:DatatypeProperty ;
    rdfs:label "Specification Name" ;
    rdfs:comment "Name/label of the specification" ;
    rdfs:domain batt:Specification ;
    rdfs:range xsd:string .

batt:unitName a owl:DatatypeProperty ;
    rdfs:label "Unit Name" ;
    rdfs:comment "Full name of the unit" ;
    rdfs:domain batt:Unit ;
    rdfs:range xsd:string .

batt:unitSymbol a owl:DatatypeProperty ;
    rdfs:label "Unit Symbol" ;
    rdfs:comment "Symbol of the unit (e.g., V, mAh, °C)" ;
    rdfs:domain batt:Unit ;
    rdfs:range xsd:string .

unit:Ampere a batt:Unit ;
    batt:unitName "Ampere" ;
    batt:unitSymbol "A" .

unit:Celsius a batt:Unit ;
    batt:unitName "Degree Celsius" ;
    batt:unitSymbol "°C" .

unit:Cycle a batt:Unit ;
    batt:unitName "Charge/Discharge Cycle" ;
    batt:unitSymbol "cycles" .

unit:Gram a batt:Unit ;
    batt:unitName "Gram" ;
    batt:unitSymbol "g" .

unit:Milliampere_Hour a batt:Unit ;
    batt:unitName "Milliampere-hour" ;
    batt:unitSymbol "mAh" .

unit:Milliohm a batt:Unit ;
    batt:unitName "Milliohm" ;
    batt:unitSymbol "mΩ" .

unit:Percent_Per_Month a batt:Unit ;
    batt:unitName "Percent per Month" ;
    batt:unitSymbol "%/month" .

unit:Volt a batt:Unit ;
    batt:unitName "Volt" ;
    batt:unitSymbol "V" .

unit:Watt_Hour a batt:Unit ;
    batt:unitName "Watt-hour" ;
    batt:unitSymbol "Wh" .

batt:Manufacturer a owl:Class ;
    rdfs:label "Manufacturer" .

batt:Battery a owl:Class ;
    rdfs:label "Battery" ;
    rdfs:comment "A battery cell or pack described by a datasheet." .

batt:Chemistry a owl:Class ;
    rdfs:label "Battery Chemistry" .

batt:Specification a owl:Class ;
    rdfs:label "Specification" ;
    rdfs:comment "A technical specification of a battery." .

batt:Unit a owl:Class ;
    rdfs:label "Unit of Measurement" .


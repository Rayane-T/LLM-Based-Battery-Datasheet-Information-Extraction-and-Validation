unit:Milliampere_Hour a batt:Unit ;
    batt:unitName "Milliampere-hour" ;
    batt:unitSymbol "mAh" .

batt:Battery a owl:Class ;
    rdfs:label "Battery" ;
    rdfs:comment "A battery cell or pack described by a datasheet." .

batt:Specification a owl:Class ;
    rdfs:label "Specification" ;
    rdfs:comment "A technical specification of a battery." .


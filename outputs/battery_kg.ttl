<http://battery-ontology.org/schema> a owl:Ontology ;
    rdfs:label "Battery Specification Ontology" ;
    rdfs:comment "An ontology for representing battery datasheet specifications, including electrical, physical, and thermal properties." .

batt:batteryModel a owl:DatatypeProperty ;
    rdfs:label "Battery Model" ;
    rdfs:comment "Model name/number of the battery" ;
    rdfs:domain batt:Battery ;
    rdfs:range xsd:string .

batt:chemistryType a owl:DatatypeProperty ;
    rdfs:label "Chemistry Type" ;
    rdfs:comment "Battery chemistry type identifier" ;
    rdfs:domain batt:Chemistry ;
    rdfs:range xsd:string .

batt:hasChemistry a owl:ObjectProperty ;
    rdfs:domain batt:Battery ;
    rdfs:range batt:Chemistry .

batt:hasManufacturer a owl:ObjectProperty ;
    rdfs:domain batt:Battery ;
    rdfs:range batt:Manufacturer .

batt:hasSpecification a owl:ObjectProperty ;
    rdfs:domain batt:Battery ;
    rdfs:range batt:Specification .

batt:hasUnit a owl:ObjectProperty ;
    rdfs:domain batt:Specification ;
    rdfs:range batt:Unit .

batt:hasValue a owl:DatatypeProperty ;
    rdfs:label "Value" ;
    rdfs:comment "Numeric value of a specification" ;
    rdfs:domain batt:Specification ;
    rdfs:range xsd:float .

batt:manufacturerName a owl:DatatypeProperty ;
    rdfs:label "Manufacturer Name" ;
    rdfs:comment "Name of the manufacturer company" ;
    rdfs:domain batt:Manufacturer ;
    rdfs:range xsd:string .

batt:specName a owl:DatatypeProperty ;
    rdfs:label "Specification Name" ;
    rdfs:comment "Name/label of the specification" ;
    rdfs:domain batt:Specification ;
    rdfs:range xsd:string .

batt:unitName a owl:DatatypeProperty ;
    rdfs:label "Unit Name" ;
    rdfs:comment "Full name of the unit" ;
    rdfs:domain batt:Unit ;
    rdfs:range xsd:string .

batt:unitSymbol a owl:DatatypeProperty ;
    rdfs:label "Unit Symbol" ;
    rdfs:comment "Symbol of the unit (e.g., V, mAh, C)" ;
    rdfs:domain batt:Unit ;
    rdfs:range xsd:string .

inst:Li-Polymer a batt:Chemistry ;
    batt:chemistryType "Li-Polymer" .

inst:manufacturer_CATL a batt:Manufacturer ;
    batt:manufacturerName "CATL" .

inst:manufacturer_DNK_Power_o_Ltd a batt:Manufacturer ;
    batt:manufacturerName "DNK Power o., Ltd." .

inst:manufacturer_EEMB_Co_Ltd a batt:Manufacturer ;
    batt:manufacturerName "EEMB Co., Ltd." .


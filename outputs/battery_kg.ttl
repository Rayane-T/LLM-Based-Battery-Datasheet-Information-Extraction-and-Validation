    batt:hasUnit unit:Volt ;
    batt:hasValue "3.65"^^xsd:float ;
    batt:specName "Charge Voltage" .

inst:spec_16340_Discharge_Cutoff_Voltage a batt:ElectricalSpecification ;
    batt:hasUnit unit:Volt ;
    batt:hasValue "2.0"^^xsd:float ;
    batt:specName "Discharge Cutoff Voltage" .

inst:spec_16340_Energy a batt:ElectricalSpecification ;
    batt:hasUnit unit:Watt_Hour ;
    batt:hasValue "1.6"^^xsd:float ;
    batt:specName "Energy" .

inst:spec_16340_Internal_Resistance a batt:ElectricalSpecification ;
    batt:hasUnit unit:Milliohm ;
    batt:hasValue "100.0"^^xsd:float ;
    batt:specName "Internal Resistance" .

inst:spec_16340_Maximum_Charge_Current a batt:ElectricalSpecification ;
    batt:hasUnit unit:Ampere ;
    batt:hasValue "0.5"^^xsd:float ;
    batt:specName "Maximum Charge Current" .

inst:spec_16340_Maximum_Discharge_Current a batt:ElectricalSpecification ;
    batt:hasUnit unit:Ampere ;
    batt:hasValue "1.0"^^xsd:float ;
    batt:specName "Maximum Discharge Current" .

inst:spec_16340_Minimum_Capacity a batt:ElectricalSpecification ;
    batt:hasUnit unit:Milliampere_Hour ;
    batt:hasValue "470.0"^^xsd:float ;
    batt:specName "Minimum Capacity" .

inst:spec_16340_Nominal_Capacity a batt:ElectricalSpecification ;
    batt:hasUnit unit:Milliampere_Hour ;
    batt:hasValue "500.0"^^xsd:float ;
    batt:specName "Nominal Capacity" .

inst:spec_16340_Nominal_Voltage a batt:ElectricalSpecification ;
    batt:hasUnit unit:Volt ;
    batt:hasValue "3.2"^^xsd:float ;
    batt:specName "Nominal Voltage" .

inst:spec_16340_Standard_Charge_Current a batt:ElectricalSpecification ;
    batt:hasUnit unit:Ampere ;
    batt:hasValue "0.1"^^xsd:float ;
    batt:specName "Standard Charge Current" .

inst:spec_16340_Weight a batt:PhysicalSpecification ;
    batt:hasUnit unit:Gram ;
    batt:hasValue "17.0"^^xsd:float ;
    batt:specName "Weight" .

